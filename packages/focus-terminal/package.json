{
  "name": "focus-terminal",
  "displayName": "J-Skills Terminal Focus",
  "description": "精确聚焦指定终端 Tab（通过 PID 匹配），配合 j-skills Monitor 使用",
  "publisher": "jackywjs",
  "version": "0.1.0",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangjs-jacky/jacky-skills-package.git",
    "directory": "packages/focus-terminal"
  },
  "bugs": {
    "url": "https://github.com/wangjs-jacky/jacky-skills-package/issues"
  },
  "homepage": "https://github.com/wangjs-jacky/jacky-skills-package/tree/main/packages/focus-terminal#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["terminal", "focus", "j-skills", "monitor"],
  "activationEvents": ["onUri"],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "build": "npm run vscode:prepublish",
    "package:vsix": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish --no-dependencies",
    "publish:all": "npm run publish:vsce && npm run publish:ovsx",
    "deploy": "npm run build && npm run publish:all"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
