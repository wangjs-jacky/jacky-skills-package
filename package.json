{
  "name": "@wangjs-jacky/j-skills",
  "version": "0.1.0",
  "description": "CLI tool for managing Agent Skills - link, install, and manage skills across 35+ coding agent environments",
  "type": "module",
  "bin": {
    "j-skills": "./bin/j-skills.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "dev:all": "pnpm run --parallel dev:server:dev & pnpm --filter @wangjs-jacky/j-skills-web dev",
    "dev:server": "pnpm --filter @wangjs-jacky/j-skills-server dev",
    "dev:web": "pnpm --filter @wangjs-jacky/j-skills-web dev",
    "build:server": "pnpm --filter @wangjs-jacky/j-skills-server build",
    "build:web": "pnpm --filter @wangjs-jacky/j-skills-web build",
    "build:all": "pnpm build && pnpm build:server && pnpm build:web",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cli",
    "claude-code",
    "skills",
    "opencode",
    "cursor",
    "ai",
    "developer-tools"
  ],
  "author": "wangjiasheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangjs-jacky/jacky-skills-package.git"
  },
  "homepage": "https://github.com/wangjs-jacky/jacky-skills-package#readme",
  "bugs": {
    "url": "https://github.com/wangjs-jacky/jacky-skills-package/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
