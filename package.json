{
  "name": "jacky-skills-package",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --stream build",
    "build:cli": "pnpm --filter @wangjs-jacky/j-skills build",
    "build:tauri": "pnpm build:cli && tauri build",
    "build:macos": "pnpm build:cli && tauri build --target universal-apple-darwin",
    "build:macos-intel": "pnpm build:cli && tauri build --target x86_64-apple-darwin",
    "build:macos-arm": "pnpm build:cli && tauri build --target aarch64-apple-darwin",
    "dev": "tauri dev",
    "dev:cli": "pnpm --filter @wangjs-jacky/j-skills dev",
    "dev:web": "pnpm --filter @wangjs-jacky/j-skills-web dev",
    "build:web": "pnpm --filter @wangjs-jacky/j-skills-web build",
    "test": "pnpm -r --stream test && vitest run tests/integration",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:tauri": "NO_PROXY='*' npx wdio run wdio.tauri.conf.ts",
    "typecheck": "pnpm -r --stream typecheck",
    "build:extension": "pnpm --filter focus-terminal build",
    "package:extension": "pnpm --filter focus-terminal package:vsix"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@wangjs-jacky/tdd-kit": "file:/Users/jiashengwang/jacky-github/jacky-tdd-kit",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "jsdom": "^29.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
