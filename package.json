{
  "name": "@wangjs-jacky/j-skills",
  "version": "0.3.1",
  "description": "CLI tool for managing Agent Skills - link, install, and manage skills across 35+ coding agent environments",
  "type": "module",
  "bin": {
    "j-skills": "./bin/j-skills.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm build:all && pnpm build:tauri",
    "dev": "pnpm pre:dev && pnpm dev:tauri",
    "pre:dev": "lsof -ti:5173 | xargs kill -9 2>/dev/null || true",
    "dev:web": "pnpm --filter @wangjs-jacky/j-skills-web dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:tauri": "NO_PROXY='*' pnpm pre:e2e:tauri && NO_PROXY='*' npx wdio run wdio.tauri.conf.ts",
    "test:e2e:tauri:debug": "NO_PROXY='*' pnpm pre:e2e:tauri && NO_PROXY='*' npx wdio run wdio.tauri.conf.ts --logLevel debug",
    "pre:e2e:tauri": "lsof -ti:5173 > /dev/null 2>&1 || (pnpm dev:web &)",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node ./dist/index.js",
    "dev:all": "pnpm run --parallel dev:server:dev & pnpm --filter @wangjs-jacky/j-skills-web dev",
    "dev:server": "pnpm --filter @wangjs-jacky/j-skills-server dev",
    "dev:tauri": "tauri dev",
    "build:server": "pnpm --filter @wangjs-jacky/j-skills-server build",
    "build:web": "pnpm --filter @wangjs-jacky/j-skills-web build",
    "build:all": "pnpm build:cli && pnpm build:web",
    "build:cli": "tsup",
    "build:tauri": "tauri build",
    "build:macos": "tauri build --target universal-apple-darwin",
    "build:macos-intel": "tauri build --target x86_64-apple-darwin",
    "build:macos-arm": "tauri build --target aarch64-apple-darwin",
    "prepublishOnly": "pnpm build:cli"
  },
  "keywords": [
    "cli",
    "claude-code",
    "skills",
    "opencode",
    "cursor",
    "ai",
    "developer-tools"
  ],
  "author": "wangjiasheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangjs-jacky/jacky-skills-package.git"
  },
  "homepage": "https://github.com/wangjs-jacky/jacky-skills-package#readme",
  "bugs": {
    "url": "https://github.com/wangjs-jacky/jacky-skills-package/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@wangjs-jacky/tdd-kit": "file:/Users/jiashengwang/jacky-github/jacky-tdd-kit",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "webdriverio": "^9.27.0"
  },
  "engines": {
    "node": ">=18"
  }
}
